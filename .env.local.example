# ──────────────────────────────────────────────
# RJ Slime Factory — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
#
# To get Stripe keys:
# 1. Create a free account at https://dashboard.stripe.com/register
# 2. Go to Developers → API Keys
# 3. Copy the Publishable key and Secret key below
# 4. Start with TEST keys (pk_test_... / sk_test_...) for development
# 5. Switch to LIVE keys when ready to accept real payments

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Secret Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=

# ──────────────────────────────────────────────
# Resend (Email)
# ──────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
